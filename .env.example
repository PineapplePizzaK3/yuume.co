# Web3Forms (formulário de contato)
VITE_WEB3FORMS_ACCESS_KEY=seu_access_key_aqui

# Supabase (autenticação + banco)
# Obtenha em https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key

# Stripe (apenas publishable key no frontend; secret key só no servidor)
# Obtenha em https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# API base URL: em produção com domínio próprio (ex.: eiko-dls.com), use /api para mesmo host.
# URL absoluta apontando para outro domínio (ex.: *.vercel.app) causa "Failed to fetch" por CORS no browser.
VITE_API_URL=/api

# [Opcional] Para dev:vite - proxy /api para URL (ex: https://seu-site.vercel.app)
# Use npm run dev (vercel dev) para rodar a API localmente
# VITE_DEV_API_PROXY=https://seu-site.vercel.app

# URL do site (para redirects do Stripe)
VITE_SITE_URL=https://eiko-dls.com

# Câmbio para exibição (aprox.) e conversão de cobrança
# BRL por 1 JPY (ex.: 0.033 = R$0,033 por ¥1)
VITE_FX_BRL_PER_JPY=0.033

# --- Variáveis APENAS no servidor (Vercel Environment Variables) ---
# Nunca adicione no .env do frontend
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# PARCELOW_CLIENT_ID=123
# PARCELOW_CLIENT_SECRET=seu_client_secret
# PARCELOW_API_BASE_URL=https://staging.parcelow.com
# PARCELOW_WEBHOOK_SECRET=seu_segredo_webhook
# FX_BRL_PER_JPY=0.033
