# Web3Forms (formulário de contato)
VITE_WEB3FORMS_ACCESS_KEY=seu_access_key_aqui

# Supabase (autenticação + banco)
# Obtenha em https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key

# Stripe (apenas publishable key no frontend; secret key só no servidor)
# Obtenha em https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# API (build SSR / ferramentas). No browser o app usa sempre /api no mesmo host, salvo override abaixo.
VITE_API_URL=/api
# Só se a API estiver em outro domínio com CORS configurado (caso raro):
# VITE_PAYMENTS_API_ORIGIN=https://seu-backend.com

# [Opcional] npm run dev (Vite) encaminha /api/* para este host (padrão 127.0.0.1:3000).
# Sem servidor escutando aí, /api/exchange-rates etc. retornam 404 — use num terminal:
#   npm run dev:full
# (vercel dev, API + front) ou rode `vercel dev` na porta 3000 e Vite em outra com VITE_DEV_API_PROXY.
# VITE_DEV_API_PROXY=http://127.0.0.1:3000

# URL do site (para redirects do Stripe)
VITE_SITE_URL=https://eiko-dls.com

# Câmbio para exibição (aprox.) e conversão de cobrança
# BRL por 1 JPY (ex.: 0.033 = R$0,033 por ¥1)
VITE_FX_BRL_PER_JPY=0.033

# --- Variáveis APENAS no servidor (Vercel Environment Variables) ---
# Nunca adicione no .env do frontend
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# RESEND_API_KEY=re_xxxxx
# ADMIN_SUPPORT_FROM=Suporte <support@seudominio.com>
# ADMIN_ALERT_FROM=Alertas <alerts@seudominio.com>
# ADMIN_ALERT_EMAILS=admin1@seudominio.com,admin2@seudominio.com
# EMAIL_BRAND_NAME=YuumeCo
# EMAIL_SUPPORT_EMAIL=suporte@seudominio.com
# EMAIL_COMPANY_ADDRESS=Rua Exemplo, 123 - Cidade/UF
# EMAIL_LOGO_URL=https://seudominio.com/logo-email.png
# PARCELOW_CLIENT_ID=123
# PARCELOW_CLIENT_SECRET=seu_client_secret
# PARCELOW_API_BASE_URL=https://staging.parcelow.com
# PARCELOW_WEBHOOK_SECRET=seu_segredo_webhook
# GLIN_API_KEY=seu_api_key_glin
# Opcional: separar chaves por ambiente (priorizado automaticamente pelo backend via GLIN_API_BASE_URL):
# GLIN_STAGING_API_KEY=seu_api_key_glin_staging
# GLIN_PRODUCTION_API_KEY=seu_api_key_glin_producao
# GLIN_API_BASE_URL=https://pay.staging.glin.com.br
# GLIN_REMITTANCES_PATH=/merchant-api/remittances/
# GLIN_REMITTANCE_CURRENCY=JPY
# GLIN_REMITTANCE_MIN_JPY=2000
# GLIN_REMITTANCE_MAX_JPY=500000
# GLIN_JWKS_URL=https://pay.glin.com.br/merchant-api/jwks.json
# GLIN_FETCH_TIMEOUT_MS=28000
# VITE_GLIN_SDK_ENABLED=false
# FX_BRL_PER_JPY=0.033
#
# Multi-moeda (JPY → USD cobrança → BRL só exibição)
# SUPABASE_SERVICE_ROLE_KEY: necessário para gravar taxas em system_settings no job de refresh.
# Provider principal sugerido: CurrencyAPI (base USD).
# CURRENCYAPI_KEY=seu_token_currencyapi
# Janela mínima entre chamadas externas de câmbio (ms).
# Padrão no código: 14400000 (4h), adequado para plano free de 300 req/mês.
# EXCHANGE_RATE_MIN_REFRESH_MS=14400000
# Fallback opcional (se provider externo falhar e o banco estiver vazio):
# FALLBACK_FX_USD_JPY=151.20
# FALLBACK_FX_USD_BRL=5.50
# Compatibilidade legado (opcional): se já usar, o serviço ainda aceita FALLBACK_FX_JPY_USD.
# FALLBACK_FX_JPY_USD=0.0066
# Markup sobre JPY→USD (retirada/conversão ex. Wise USD→JPY). Padrão no código 0,73 se env omitido.
# Se definido, tem prioridade sobre system_settings.wise_usd_jpy_withdrawal_markup_percent.
# Use 0 para desativar (não recomendado se o custo Wise existir).
# WISE_USD_TO_JPY_WITHDRAWAL_MARKUP_PERCENT=0.73
# Percentuais de margem (só triggers SQL legados em produtos / admin settings)
# PRICING_MARGIN_PERCENT=0
# PRICING_PLATFORM_FEE_PERCENT=0
# PRICING_JPY_USD_BUFFER_PERCENT=5
# CRON_SECRET=defina_na_Vercel_para_proteger_o_cron (também usado no GitHub Actions)
# Parcelow: use POST /api/orders (USD no body). Só altere se a Parcelow indicar outro path.
# PARCELOW_ORDERS_PATH=/api/orders
# Aderência ao contrato /api/orders (Swagger): items[].amount em centavos de USD.
